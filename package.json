{
  "name": "picket",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3019",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
