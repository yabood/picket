# Postgres (Neon, auto-provisioned via Vercel Marketplace)
DATABASE_URL=

# Vercel AI Gateway — powers both the relevance gate and fact extraction (Haiku 4.5).
# See https://vercel.com/docs/ai-gateway. At deploy time prefer the OIDC token flow
# (`vercel env pull`) over a long-lived key so rotation is automatic.
AI_GATEWAY_API_KEY=

# Slack incoming webhook for the #regulatory-watch channel.
# Optional locally — when unset, the sink writes markdown to notifications/ (FileSink).
SLACK_WEBHOOK_URL=

# Cron auth — Vercel sends `Authorization: Bearer <CRON_SECRET>` automatically when set.
# 32+ char random string: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=
